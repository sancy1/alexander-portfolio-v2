# ============================================================================
.env
.env.local
.env.*.local
.env.production
.prod.yml
*.secrets
**/appsettings.Production.json

# Production deployment files (local only)
*.prod.yml
docker-compose.override.yml

# Build outputs
**/bin/
**/obj/
**/out/
**/Debug/
**/Release/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Node modules
node_modules/
.nx/
.nx/cache/

# Logs
