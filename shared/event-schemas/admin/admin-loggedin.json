{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdminLoggedInEvent",
  "description": "Emitted when an admin successfully logs in",
  "type": "object",
  "allOf": [{ "$ref": "../common/event-base.json" }],
  "properties": {
    "eventType": { "const": "admin.loggedin" },
    "data": {
      "type": "object",
      "properties": {
        "adminId": { "type": "string", "format": "uuid" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "loginAt": { "type": "string", "format": "date-time" }
      },
      "required": ["adminId", "username", "email"]
    }
  }
}
