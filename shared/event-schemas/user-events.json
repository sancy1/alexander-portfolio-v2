
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "User Events",
  "description": "Event schemas for user-related messages",
  "definitions": {
    "UserRegisteredEvent": {
      "type": "object",
      "properties": {
        "eventType": { "type": "string", "const": "user.registered" },
        "version": { "type": "string", "const": "1.0.0" },
        "timestamp": { "type": "string", "format": "date-time" },
        "data": {
          "type": "object",
          "properties": {
            "userId": { "type": "string", "format": "uuid" },
            "email": { "type": "string", "format": "email" },
            "provider": { "type": "string", "enum": ["Google", "GitHub"] },
            "displayName": { "type": "string" }
          },
          "required": ["userId", "email", "provider"]
        }
      },
      "required": ["eventType", "version", "timestamp", "data"]
    },
    "UserLoggedInEvent": {
      "type": "object",
      "properties": {
        "eventType": { "type": "string", "const": "user.loggedin" },
        "version": { "type": "string", "const": "1.0.0" },
        "timestamp": { "type": "string", "format": "date-time" },
        "data": {
          "type": "object",
          "properties": {
            "userId": { "type": "string", "format": "uuid" },
            "ipAddress": { "type": "string" },
            "userAgent": { "type": "string" }
          },
          "required": ["userId"]
        }
      },
      "required": ["eventType", "version", "timestamp", "data"]
    }
  }
}
