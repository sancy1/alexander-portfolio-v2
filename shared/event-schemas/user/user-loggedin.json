{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UserLoggedInEvent",
  "description": "Emitted when a user successfully logs in",
  "type": "object",
  "allOf": [{ "$ref": "../common/event-base.json" }],
  "properties": {
    "eventType": { "const": "user.loggedin" },
    "data": {
      "type": "object",
      "properties": {
        "userId": { "type": "string", "format": "uuid" },
        "email": { "type": "string", "format": "email" },
        "provider": { "type": "string", "enum": ["Google", "GitHub"] },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "loginAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "provider"]
    }
  }
}
