{
  "name": "auth-service",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "services/auth-service",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build AuthService.sln --configuration Release",
        "cwd": "services/auth-service"
      }
    },
    "build-dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build AuthService.sln --configuration Debug",
        "cwd": "services/auth-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test AuthService.sln --no-build --configuration Release",
        "cwd": "services/auth-service"
      }
    },
    "restore": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet restore AuthService.sln",
        "cwd": "services/auth-service"
      }
    },
    "docker-build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "docker build -t portfolio/auth-service:latest -f Dockerfile .",
        "cwd": "services/auth-service"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run --project AuthService.API/AuthService.API.csproj",
        "cwd": "services/auth-service"
      }
    }
  },
  "tags": ["scope:backend", "language:csharp", "stack:dotnet"]
}
