{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BaseEvent",
  "description": "Base schema for all events in the portfolio system",
  "type": "object",
  "properties": {
    "eventId": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for the event"
    },
    "eventType": {
      "type": "string",
      "description": "Type of event (e.g., user.registered, admin.created)"
    },
    "eventVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the event schema",
      "default": "1.0.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when event occurred"
    },
    "source": {
      "type": "string",
      "description": "Service that emitted the event",
      "enum": ["auth-service", "blog-service", "ai-service", "core-info-service", "api-gateway"]
    },
    "correlationId": {
      "type": "string",
      "format": "uuid",
      "description": "ID to correlate related events across services"
    },
    "userId": {
      "type": "string",
      "format": "uuid",
      "description": "ID of the user who triggered the event (if applicable)"
    },
    "data": {
      "type": "object",
      "description": "Event-specific payload"
    }
  },
  "required": ["eventId", "eventType", "timestamp", "source", "data"]
}
