{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AdminPasswordChangedEvent",
  "description": "Emitted when an admin changes their password",
  "type": "object",
  "allOf": [{ "$ref": "../common/event-base.json" }],
  "properties": {
    "eventType": { "const": "admin.password.changed" },
    "data": {
      "type": "object",
      "properties": {
        "adminId": { "type": "string", "format": "uuid" },
        "username": { "type": "string" },
        "changedAt": { "type": "string", "format": "date-time" },
        "changedBy": { "type": "string", "description": "Self or another admin" }
      },
      "required": ["adminId", "username"]
    }
  }
}
